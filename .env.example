# =============================================================================
# Rachael — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# On DO: the install script will prompt for these interactively.
# =============================================================================

# --- Required ---

# PostgreSQL connection string
# On DO the installer creates a local database automatically:
#   DATABASE_URL=postgresql://rachael:YOUR_DB_PASSWORD@localhost:5432/rachael
DATABASE_URL=

# At least one LLM provider API key is required.
# OpenRouter is recommended — it gives access to all models via one key.
OPENROUTER_API_KEY=

# API key that protects all write endpoints (POST/PUT/PATCH/DELETE).
# Also used by the Chrome extension and CLI to authenticate.
# Generate one: openssl rand -hex 32
OPENCLAW_API_KEY=

# Shared secret between the server and Chrome extension.
# The extension sends this in the X-Bridge-Token header.
# Generate one: uuidgen   (or use any random string)
BRIDGE_TOKEN=

# --- Optional ---

# Server port (default: 5000)
PORT=5000

# Node environment: "production" or "development"
NODE_ENV=production

# ntfy.sh notification channel for digests/alerts
NTFY_CHANNEL=rachael-standup

# Email address for ntfy.sh email delivery
NTFY_EMAIL=

# Anthropic API key (direct, bypasses OpenRouter)
# ANTHROPIC_API_KEY=

# OpenAI API key (direct, bypasses OpenRouter)
# OPENAI_API_KEY=

# --- Qdrant (optional vector memory) ---
# If not set, falls back to PostgreSQL for memory storage.
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# --- Self-Hosted Mode ---
# Set to "true" when running on your own server (DO, VPS, etc).
# Enables native shell execution for programs that would otherwise
# need Phantom. Programs with computeTarget=phantom or auto will
# execute bash commands locally instead of routing to a remote bridge.
RACHAEL_SELF_HOSTED=true

# --- Phantom Compute Bridge (optional) ---
# Only needed if NOT self-hosted and you want to delegate tasks to another instance.
# PHANTOM_URL=https://your-phantom-instance.com
# PHANTOM_API_KEY=

# --- Domain (for SSL/Caddy) ---
# Set this to your domain name for automatic HTTPS via Caddy.
# If not set, Caddy will serve on the IP with a self-signed cert.
# RACHAEL_DOMAIN=rachael.yourdomain.com
