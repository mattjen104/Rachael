{
  "manifest_version": 3,
  "name": "OrgCloud Bridge",
  "version": "2.5.0",
  "description": "Personal browser bridge for OrgCloud — scrapes any site you're logged into",
  "permissions": [
    "activeTab",
    "tabs",
    "tabCapture",
    "offscreen",
    "scripting",
    "storage",
    "sidePanel",
    "alarms",
    "downloads",
    "downloads.open"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "OrgCloud Bridge"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+C"
      },
      "description": "Open OrgCloud Space capture"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
