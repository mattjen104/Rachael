{
  "manifest_version": 3,
  "name": "Rachael Bridge",
  "version": "7.0.0",
  "description": "Personal browser bridge for Rachael — scrapes any site you're logged into",
  "permissions": [
    "activeTab",
    "tabs",
    "tabCapture",
    "offscreen",
    "scripting",
    "storage",
    "alarms",
    "downloads",
    "downloads.open",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Rachael Bridge"
  },
  "commands": {
    "open-command": {
      "suggested_key": {
        "default": "Alt+X"
      },
      "description": "Open command palette (M-x)"
    },
    "open-capture": {
      "suggested_key": {
        "default": "Alt+C"
      },
      "description": "Open capture mode"
    },
    "open-search": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Open search mode"
    },
    "open-agenda": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Open agenda view"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
